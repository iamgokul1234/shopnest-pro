# Auto detect text files and perform LF normalization
* text=auto

# Force bash scripts to always use LF
*.sh text eol=lf

# Force batch scripts to always use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.pdf binary