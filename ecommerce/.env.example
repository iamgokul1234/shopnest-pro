# ============================================================
# ShopNest Pro — Frontend Environment Variables TEMPLATE
# ============================================================
# This is a SAFE template file. It shows which variables are
# needed but contains NO real secrets.
#
# HOW TO USE:
# 1. Copy this file → rename to ".env"
# 2. Fill in your real values
# 3. Never commit .env — only commit this .env.example file
# ============================================================

# --- Product API ---
VITE_API_BASE_URL=https://dummyjson.com

# --- Contact Form ---
# Get your free key at: https://web3forms.com
VITE_WEB3FORMS_KEY=your_web3forms_key_here

# --- Backend API (Phase 2 onwards) ---
# VITE_BACKEND_URL=http://localhost:5000/api

VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here